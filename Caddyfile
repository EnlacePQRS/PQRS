:{$PORT}

encode gzip

# Redirigir las rutas del backend de Reflex (Eventos, Websockets, Ping, Cargas)
@backend_routes path /_event/* /ping /_upload /_upload/*
handle @backend_routes {
	reverse_proxy localhost:8000
}

# Servir el frontend compilado de forma estática
root * /srv
route {
	try_files {path} {path}/ /404.html
	file_server
}
